# ============================================================
# PharmaOS — Variables de production
# ============================================================
# Copier ce fichier en `.env` puis adapter avant `docker compose up`.

# Domaine (DNS doit pointer vers le VPS)
DOMAIN=pharmaos.example.com

# Clé secrète (générer : openssl rand -hex 32)
SECRET_KEY=CHANGE-ME-PRODUCTION-SECRET-AT-LEAST-32-CHARACTERS-LONG

# Database
POSTGRES_USER=pharmaos
POSTGRES_PASSWORD=CHANGE-ME-strong-password
POSTGRES_DB=pharmaos

# Anthropic Claude API (OCR ordonnance, PharmaBot, anomaly detection)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Twilio (optionnel — relances crédit WhatsApp/SMS)
# Si vide, mode preview (les relances sont enregistrées mais pas envoyées)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_SMS=
TWILIO_FROM_WHATSAPP=
